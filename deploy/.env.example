# Telegram бот
TELEGRAM_BOT_TOKEN=
ADMIN_IDS=

# Ключ защиты API — тот же, что CC_API_KEY в .env на домашнем Windows-ПК
# Генерация: openssl rand -base64 40
CC_API_KEY=

# FastAPI на домашнем ПК, доступный через Tailscale / VPN / SSH-туннель
# Пример (Tailscale IP Windows): http://100.x.x.x:8765
# НЕ используйте host.docker.internal — на Linux VPS это не ваш ПК
FASTAPI_URL=

# Seq на домашнем Windows (Tailscale IP + SEQ_PORT из корневого .env)
SEQ_ADDRESS=
