# Telegram бот
TELEGRAM_BOT_TOKEN=
ADMIN_IDS=

# Ключ защиты API — должен совпадать с CC_API_KEY в корневом .env
# Генерация: openssl rand -base64 40
CC_API_KEY=

# Адрес FastAPI сервиса на хосте Windows (пример: http://host.docker.internal:PORT)
FASTAPI_URL=

# Seq — больше не нужен, логи идут через Fluent Bit
